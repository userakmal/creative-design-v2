# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Local Bot API Server (for 2GB uploads)
# Leave empty to use standard Telegram API (50MB limit)
# Example: http://localhost:8081
TELEGRAM_API_SERVER=

# Local Bot API Server file path
TELEGRAM_API_LOCAL_PATH=

# Database Configuration
# Options: sqlite, redis
DB_TYPE=sqlite

# SQLite Configuration
SQLITE_DB_PATH=cache.db

# Redis Configuration (if using Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTL in seconds (default: 7 days)
CACHE_TTL=604800

# Downloader Configuration
DOWNLOAD_DIR=downloads

# Maximum file size in bytes
# Standard API: 52428800 (50MB)
# Local Server: 2147483648 (2GB)
MAX_FILE_SIZE=2147483648

# yt-dlp Configuration
YTDLP_FORMAT=best[ext=mp4]/best
YTDLP_TIMEOUT=300

# FFmpeg Configuration
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Enable HLS (.m3u8) processing
ENABLE_HLS_PROCESSING=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=bot.log
