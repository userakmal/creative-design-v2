<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, Range"
    # Security headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# GZIP Compression — JS/CSS/HTML/JSON/SVG siqish
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml application/xml
    AddOutputFilterByType DEFLATE application/font-woff2 font/woff2
</IfModule>

# Proper MIME types for media files
<IfModule mod_mime.c>
    AddType video/mp4 .mp4
    AddType image/jpeg .jpg .jpeg
    AddType image/png .png
    AddType image/webp .webp
    AddType audio/mpeg .mp3
    AddType audio/mp4 .m4a
    AddType application/json .json
    AddType font/woff2 .woff2
</IfModule>

# Aggressive caching — Lighthouse "efficient cache lifetimes" tuzatish
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # Build assets (JS/CSS) — Vite hash qo'shadi, 1 yil cache
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"

    # Media fayllar — 1 yil cache
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType audio/mpeg "access plus 1 year"
    ExpiresByType audio/mp4 "access plus 1 year"

    # Fontlar — 1 yil
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # HTML — har doim yangi
    ExpiresByType text/html "access plus 0 seconds"

    # JSON data — 1 soat
    ExpiresByType application/json "access plus 1 hour"
</IfModule>

# Cache-Control headers — immutable for hashed assets
<IfModule mod_headers.c>
    # Vite hashed assets (e.g. index-abc123.js) — immutable
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # Media files — long cache
    <FilesMatch "\.(jpg|jpeg|png|webp|mp4|mp3|m4a|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # HTML — no cache
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Do NOT rewrite actual files (videos, images, music, data, assets)
  RewriteRule ^index\.html$ - [L]

  # Skip rewrite for media/static file extensions
  RewriteRule \.(mp4|webm|mov|avi|jpg|jpeg|png|gif|webp|svg|mp3|m4a|ogg|wav|json|js|css|ico|woff|woff2|ttf|eot|xml)$ - [L,NC]

  # Skip rewrite for media directories
  RewriteRule ^(videos|image|music|data|assets|logo)/ - [L]

  # SPA catch-all — only for non-file non-directory requests
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
