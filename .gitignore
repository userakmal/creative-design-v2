# =============================================================================
# Creative Design Platform - Gitignore
# =============================================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
*.swp
*.swo
*~

# Logs
logs/
*.log
api-server/*.log

# Environment variables
.env
.env.local
.env.production
.env.*.local
!.env.example

# Database
*.db
*.sqlite
*.sqlite3

# Downloads (video downloader temp files)
api-server/video-downloader/downloads/*.mp4
api-server/video-downloader/downloads/*.part
api-server/video-downloader/downloads/*.ytdl
api-server/video-downloader/downloads/hls_*/

# Uploaded media (stored on hosting CDN, not in git)
api-server/public/videos/
api-server/public/image/
api-server/public/music/
api-server/public/data/*.json

# Sensitive files
cookies.txt

# Cache
.cache/
*.cache
api-server/video-downloader/cache.db
api-server/video-downloader/downloads/*.db

# OS
Thumbs.db
.DS_Store
desktop.ini

# Build output
dist/
client/dist/

# Temporary
tmp/
temp/
*.tmp

# Test files
test-*.mjs
test-*.js
test_*.py

# Backup files
*.bak
*.backup
*.old
